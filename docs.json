{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Akapulu Labs",
  "variables": {
    "app-url": "https://akapulu.com",
    "api-base-url": "https://akapulu.com/api"
  },
  "description": "Akapulu Labs is an AI research lab building a platform for real-time conversational avatars for natural voice and video interactions.",
  "redirects": [
    {
      "source": "/",
      "destination": "/quickstart"
    },
    {
      "source": "/blog/welcome-to-the-akapulu-blog",
      "destination": "/blog/what-is-akapulu/what-is-akapulu"
    },
    {
      "source": "/blog/what-is-akapulu",
      "destination": "/blog/what-is-akapulu/what-is-akapulu"
    }
  ],
  "colors": {
    "primary": "#2D5C70",
    "light": "#38BDF8",
    "dark": "#1E3F4D"
  },
  "favicon": "/logo/logo_no_words.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "quickstart",
              "guides/getting-started/how-akapulu-works"
            ]
          },
          {
            "group": "Scenarios",
            "pages": [
              "guides/scenarios/overview",
              "guides/scenarios/role-and-task-instructions",
              "guides/scenarios/llm-test-mode",
              "guides/scenarios/using-json",
              "guides/scenarios/node-basics"
            ]
          },
          {
            "group": "Avatars",
            "pages": [
              "guides/avatars/avatar-catalog"
            ]
          },
          {
            "group": "Conversations",
            "pages": [
              "guides/conversations/lifecycle",
              "guides/conversations/customize-conversation-ui"
            ]
          },
          {
            "group": "Tools",
            "pages": [
              "guides/tools/transition-tools",
              {
                "group": "Endpoints",
                "pages": [
                  "guides/endpoints/create-endpoint",
                  "guides/endpoints/templates-and-variables"
                ]
              },
              "guides/knowledge-bases/overview",
              "guides/vision/vision-tool-overview"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Starting a conversation",
            "pages": [
              "api-reference/conversations/connect",
              "api-reference/conversations/updates"
            ]
          },
          {
            "group": "Transcripts and recordings",
            "pages": [
              "api-reference/conversations/detail",
              "api-reference/conversations/recording"
            ]
          }
        ]
      },
      {
        "tab": "Web SDK",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "web-sdk/overview"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "web-sdk/callbacks-and-events",
              "web-sdk/server-sdk",
              "web-sdk/react-sdk",
              "web-sdk/react-ui"
            ]
          }
        ]
      },
      {
        "tab": "Examples",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "examples/index"
            ]
          },
          {
            "group": "Basic",
            "pages": [
              "examples/basic/prebuilt-ui",
              "examples/basic/custom-ui"
            ]
          },
          {
            "group": "Example Scenarios",
            "pages": [
              "examples/scenarios/healthcare-intake-scheduling",
              "examples/scenarios/sales-roleplay-training"
            ]
          }
        ]
      },
      {
        "tab": "Blog",
        "groups": [
          {
            "group": "Blog",
            "pages": [
              "blog/index"
            ]
          },
          {
            "group": "Posts",
            "pages": [
              "blog/what-is-akapulu/what-is-akapulu"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/logo_dark.png",
    "dark": "/logo/logo.png",
    "href": "https://akapulu.com"
  },
  "appearance": {
    "default": "dark"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@akapulu.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Sign in",
      "href": "https://akapulu.com/accounts/login/"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "youtube": "https://www.youtube.com/@JamesAkapulu",
      "linkedin": "https://www.linkedin.com/company/akapulu-ai/"
    }
  }
}
