{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Akapulu",
  "description": "Akapulu builds conversational avatars for natural, real-time voice and video interactions.",
  "colors": {
    "primary": "#2D5C70",
    "light": "#38BDF8",
    "dark": "#1E3F4D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Core guides",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Authoring",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          }
        ]
      },
      {
        "tab": "Examples",
        "groups": [
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/logo_dark.png",
    "dark": "/logo/logo.png",
    "href": "https://akapulu-dev.fly.dev"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:william@akapulu.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Sign in",
      "href": "https://akapulu-dev.fly.dev/accounts/login/"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "youtube": "https://www.youtube.com/@JamesAkapulu",
      "linkedin": "https://www.linkedin.com/company/akapulu-ai/"
    }
  }
