digraph AkapuluPipeline {
  graph [
    rankdir=LR,
    fontsize=12,
    fontname="Helvetica",
    fontcolor="#E5E7EB",
    bgcolor="#0b0d10",
    pad=0.8,
    nodesep=0.6,
    imagepath="/Users/williambradford/Documents/akapulu/akapulu-ai-2026/docs/images/guides/getting-started/How-akapulu-works/pipeline-diagram"
  ];

  node [
    fontname="Helvetica",
    fontsize=11,
    shape=box,
    style="filled",
    color="#0B1E5B",
    fillcolor="#1E3A8A",
    fontcolor="#E2E8F0"
  ];

  edge [
    fontname="Helvetica",
    fontsize=10,
    color="#CBD5E1",
    fontcolor="#E2E8F0",
    arrowsize=0.8
  ];

  user [
    label="User",
    shape=box,
    style="rounded,filled",
    margin="1",
    color="#4C1D95",
    fillcolor="#6D28D9",
    fontcolor="#E2E8F0",
    image="user-icon.png",
    imagescale=true,
    imagepos="bc",
    labelloc="t",
    fixedsize=true,
    width=0.8,
    height=0.9
  ];

  subgraph cluster_akapulu {
    label="Akapulu";
    color="#0C4A6E";
    fontcolor="#E2E8F0";
    penwidth=1.6;
    style="rounded,filled";
    fillcolor="#1E3A5F";
    ranksep=0.8;

    stt [label="Speech-to-Text"];
    llm [label="LLM"];
    tts [label="Text-to-Speech"];
    avatar [label="Avatar Rendering"];

    { rank=same; stt; llm; tts; avatar; }
    avatar -> tts [style=invis, weight=100];
    tts -> llm [style=invis, weight=100];
    llm -> stt [style=invis, weight=100];
    stt -> llm [
      constraint=false,
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLPADDING="3" BGCOLOR="#334155" COLOR="#1F2937">
          <TR><TD><FONT COLOR="#D1D9E6">User text:</FONT></TD></TR>
          <TR><TD><FONT COLOR="#D1D9E6">"I need to reschedule my appointment."</FONT></TD></TR>
        </TABLE>
      >,
    ];
    llm -> tts [
      constraint=false,
      weight=3,
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLPADDING="3" BGCOLOR="#334155" COLOR="#1F2937">
          <TR><TD><FONT COLOR="#D1D9E6">LLM response:</FONT></TD></TR>
          <TR><TD><FONT COLOR="#D1D9E6">"I can help with that. What day works best for you?"</FONT></TD></TR>
        </TABLE>
      >
    ];
    tts -> avatar [
      constraint=false,
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLPADDING="3" BGCOLOR="#334155" COLOR="#1F2937">
          <TR><TD><IMG SRC="bot-audiowaves.png" SCALE="TRUE"/></TD></TR>
          <TR><TD><FONT COLOR="#D1D9E6">Bot audio</FONT></TD></TR>
        </TABLE>
      >
    ];
  }

  user:e -> stt:w [
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLPADDING="3">
        <TR><TD><IMG SRC="user-audio-waves.png" SCALE="TRUE"/></TD></TR>
        <TR><TD><FONT COLOR="#E2E8F0">User input audio</FONT></TD></TR>
      </TABLE>
    >,
    minlen=2
  ];
  avatar:w -> user:s [
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLPADDING="3">
        <TR>
          <TD><IMG SRC="avatar_output_thumb.png" SCALE="TRUE"/></TD>
          <TD><FONT POINT-SIZE="14" COLOR="#E2E8F0">+</FONT></TD>
          <TD><IMG SRC="bot-audiowaves.png" SCALE="TRUE"/></TD>
        </TR>
        <TR><TD COLSPAN="3"><FONT COLOR="#E2E8F0">Bot output video / audio</FONT></TD></TR>
      </TABLE>
    >,
    constraint=false
  ];
}
